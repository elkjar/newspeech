.DS_Store
.claude/
node_modules/
dist/
_site/

# vst/ build artifacts (Faust + JUCE)
vst/*/Builds/
vst/*/build/
vst/*/cmake-build-*/
vst/*/*.vst3
vst/*/*.component
# Regenerated by faust2juce + Projucer on every build — kept out of git.
# *.jucer, Source/, assets/ ARE tracked (hand-edited / hand-authored).
vst/*/juce/*/Builds/
vst/*/juce/*/JuceLibraryCode/
vst/*/juce/*/FaustPluginProcessor.cpp
# faust2au build temp dir (legacy build.sh)
vst/*/dsp/faustAUtmp.*/
# Re-include vst plug-in distribution dirs (entitlements, sign-and-notarize.sh,
# .signing-config.example) — the global `dist/` rule above would otherwise
# catch them along with web build outputs.
!vst/*/dist/
# But never commit the real signing credentials.
vst/*/dist/.signing-config
