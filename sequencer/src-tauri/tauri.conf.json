{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sequence",
  "version": "0.3.1",
  "identifier": "com.newspeechsound.sequencer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sequence",
        "width": 1500,
        "height": 960,
        "minWidth": 1500,
        "minHeight": 920,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Documents/newspeech-visuals/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../public/samples": "samples"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
