{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sequence",
  "version": "../package.json",
  "identifier": "com.newspeechsound.sequencer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sequence",
        "width": 1500,
        "height": 960,
        "minWidth": 1500,
        "minHeight": 920,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Documents/newspeech-visuals/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": "./Entitlements.plist"
    },
    "fileAssociations": [
      {
        "ext": ["seq", "seqcomp"],
        "name": "newspeech song",
        "description": "newspeech sequence song",
        "role": "Editor",
        "mimeType": "application/json"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0NEJGNEExMDk4NDQ2NzgKUldSNFJvUUpvZlJMTkMvVmNkVDNCTEF5WGFwNXdvS1psK3NjQ0NFeksrOVRZNUxlVjNLNms4REUK",
      "endpoints": [
        "https://github.com/elkjar/newspeech/releases/latest/download/latest.json"
      ]
    }
  }
}
