<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>com.newspeechsound.sequencer</string>
  <key>CFBundleName</key>
  <string>Sequence</string>
  <key>CFBundleDisplayName</key>
  <string>Sequence</string>
  <!-- Version keys intentionally omitted: Tauri injects CFBundleShortVersionString
       / CFBundleVersion from the app version (tauri.conf.json → ../package.json),
       so the release version lives in package.json only. -->
  <key>LSMinimumSystemVersion</key>
  <string>10.15</string>
  <key>NSHighResolutionCapable</key>
  <true/>
  <key>NSMicrophoneUsageDescription</key>
  <string>Sequence needs microphone access to list available audio output devices for routing.</string>
  <key>NSCameraUsageDescription</key>
  <string>Sequence uses the camera as a live video source for the stream window's visualizer modes.</string>
</dict>
</plist>
